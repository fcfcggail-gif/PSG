  - name: 🚀 Proxy
    type: select
    proxies:
      - ♻️ Auto
      - 🎯 Direct

  - name: ♻️ Auto
    type: url-test
    url: http://www.gstatic.com/generate_204
    interval: 300
    proxies: 
      - '🇸🇬 SG | VLESS | @bored_vpn #1'
      - '🇸🇬 SG | VLESS | @bored_vpn #2'
      - '🇸🇬 SG | VLESS | @itv2ray #1'
